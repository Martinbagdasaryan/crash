{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2020",
		"esModuleInterop": true,
		"moduleResolution": "node",
		"paths": {
			"models/*": ["./shared-models/models/*", "./shared-models/models/"],
			"dbSrc/*": ["./shared-models/src/*", "./shared-models/src/"]
		},
		"types": ["node"],
		"resolveJsonModule": true,
		"outDir": "build",
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*", "models", ".env"]
}
